{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["preload.ts"],
  "exclude": ["../src/types/**/*.test.ts"]
}
